# Backend Environment Variables — Copy to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://futurelens:futurelens_secret@localhost:5432/futurelens_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── OpenAI (optional — fallback to template explanations if not set) ──────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=FutureLens
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Monte Carlo ───────────────────────────────────────────────────────────────
MONTE_CARLO_SIMULATIONS=10000
MONTE_CARLO_SEED=42
